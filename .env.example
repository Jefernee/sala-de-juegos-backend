# ============================================
# Variables de entorno — Sala de Juegos Backend
# Copiá este archivo a .env y completá los valores reales.
# El .env real NUNCA se sube al repo (está en .gitignore).
# ============================================

# --- Base de datos ---
MONGO_URI=mongodb+srv://usuario:password@cluster.mongodb.net/nombre-db

# --- Servidor ---
PORT=8000

# --- Autenticación ---
JWT_SECRET=pon-aca-un-secreto-largo-y-aleatorio

# --- Cloudinary (imágenes) ---
CLOUDINARY_CLOUD_NAME=tu-cloud-name
CLOUDINARY_API_KEY=tu-api-key
CLOUDINARY_API_SECRET=tu-api-secret

# --- Frontend ---
FRONTEND_URL=https://tu-frontend.netlify.app

# ============================================
# Notificaciones por WhatsApp (CallMeBot)
# Ver utils/notificacionesWhatsApp.js
# ============================================
# 'true' para activar los avisos automáticos de fin de sesión. Cualquier otro
# valor (o vacío) los apaga sin tocar código.
NOTIFICACIONES_WHATSAPP_ENABLED=false

# Destinatarios de WhatsApp. CallMeBot NO soporta grupos: cada persona recibe el
# mensaje en su propio número y cada número tiene SU PROPIA apikey.
# Formato: lista separada por comas de "numero:apikey".
#   - numero: en formato internacional, con "+" y código de país (Costa Rica = +506).
#   - apikey: la que CallMeBot le da a ESA persona al activar el bot en su WhatsApp.
# Ejemplo con dos personas:
CALLMEBOT_RECIPIENTS=+50688881234:111111,+50677775678:222222
